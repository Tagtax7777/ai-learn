<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tagtax.mapper.KnowledgeCardMapper">

    <!-- 根据任务ID获取知识卡片列表 -->
    <select id="getCardsByTaskId" resultType="com.tagtax.entity.KnowledgeCard">
        SELECT * FROM knowledge_cards
        WHERE task_id = #{taskId}
        ORDER BY id ASC
    </select>

    <!-- 删除知识卡片 -->
    <delete id="deleteCard">
        DELETE FROM knowledge_cards WHERE id = #{cardId}
    </delete>

    <!-- 批量创建知识卡片 -->
    <insert id="batchCreateCards" parameterType="java.util.List" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO knowledge_cards
        (task_id, card_name, explanation, example, created_at, updated_at)
        VALUES
        <foreach collection="cards" item="card" separator=",">
            (#{card.taskId}, #{card.cardName}, #{card.explanation}, #{card.example}, NOW(), NOW())
        </foreach>
    </insert>

</mapper>
