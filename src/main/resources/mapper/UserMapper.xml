<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tagtax.mapper.UserMapper" >

    <select id="queryUserByPhone" resultType="com.tagtax.entity.User">
        select * from users where phone = #{phone}
    </select>

    <select id="queryUserByUsername" resultType="com.tagtax.entity.User">
        select * from users where username = #{username}
    </select>

    <insert id="addOneUser">
        insert into users(username, phone)
            VALUE (#{username}, #{phone})
    </insert>

    <select id="queryUserById" resultType="com.tagtax.entity.User">
        select * from users where id = #{id}
    </select>
</mapper>